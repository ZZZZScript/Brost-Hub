-- INSTANT LEAVE TOGGLE (COM BOTÃO FLUTUANTE - CORRIGIDO)
-- ============================================
local leaveEnabled = false
local floatingLeaveButton = nil

local function createFloatingLeaveButton()
    -- Destroi botão antigo se existir
    if floatingLeaveButton and floatingLeaveButton.Parent then
        pcall(function() floatingLeaveButton:Destroy() end)
        floatingLeaveButton = nil
    end
    
    -- Cria um ScreenGui separado para o botão flutuante (garantia de visibilidade)
    local floatingGui = Instance.new("ScreenGui")
    floatingGui.Name = "LeaveFloatingGui"
    floatingGui.ResetOnSpawn = false
    floatingGui.DisplayOrder = 999999
    floatingGui.Parent = gui_parent
    
    -- Garante que o GUI está visível
    pcall(function()
        if syn and syn.protect_gui then
            syn.protect_gui(floatingGui)
        end
    end)
    
    floatingLeaveButton = Instance.new("TextButton")
    floatingLeaveButton.Name = "LeaveFloatingButton"
    floatingLeaveButton.Size = UDim2.new(0, 140, 0, 50)
    floatingLeaveButton.Position = UDim2.new(0.5, -70, 0.85, 0)
    floatingLeaveButton.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
    floatingLeaveButton.Text = "🚪 INSTANT LEAVE"
    floatingLeaveButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    floatingLeaveButton.TextSize = 14
    floatingLeaveButton.Font = Enum.Font.GothamBold
    floatingLeaveButton.AutoButtonColor = false
    floatingLeaveButton.Parent = floatingGui
    floatingLeaveButton.ZIndex = 999999
    
    -- Borda arredondada
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = floatingLeaveButton
    
    -- Borda branca
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Thickness = 2
    stroke.Transparency = 0.2
    stroke.Parent = floatingLeaveButton
    
    -- Sombra
    local shadow = Instance.new("UIShadow")
    shadow.Size = 5
    shadow.Parent = floatingLeaveButton
    
    -- Efeito de pulsar (animação)
    task.spawn(function()
        while floatingLeaveButton and floatingLeaveButton.Parent and leaveEnabled do
            for i = 1, 2 do
                pcall(function()
                    floatingLeaveButton.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
                    stroke.Transparency = 0.2
                end)
                task.wait(0.3)
                pcall(function()
                    floatingLeaveButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                    stroke.Transparency = 0
                end)
                task.wait(0.3)
            end
        end
    end)
    
    -- Dragging do botão flutuante
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    floatingLeaveButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = floatingLeaveButton.Position
            stroke.Transparency = 0
        end
    end)
    
    floatingLeaveButton.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            floatingLeaveButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    floatingLeaveButton.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            stroke.Transparency = 0.2
        end
    end)
    
    -- Clique para sair
    floatingLeaveButton.MouseButton1Click:Connect(function()
        LocalPlayer:Kick("REHUB - Instant Leave")
    end)
    
    floatingLeaveButton.TouchTap:Connect(function()
        LocalPlayer:Kick("REHUB - Instant Leave")
    end)
    
    print("[REHUB] ✅ Botão flutuante criado com sucesso!")
end

local function removeFloatingLeaveButton()
    if floatingLeaveButton then
        local parent = floatingLeaveButton.Parent
        pcall(function() floatingLeaveButton:Destroy() end)
        if parent and parent ~= gui_parent then
            pcall(function() parent:Destroy() end)
        end
        floatingLeaveButton = nil
    end
    -- Limpa qualquer GUI residual
    local existingGui = gui_parent:FindFirstChild("LeaveFloatingGui")
    if existingGui then
        pcall(function() existingGui:Destroy() end)
    end
end

local function doInstantLeave()
    LocalPlayer:Kick("REHUB - Instant Leave")
end

