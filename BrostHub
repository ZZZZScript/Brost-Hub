        for _, otherPlayer in ipairs(Players:GetPlayers()) do
            if otherPlayer ~= LocalPlayer and otherPlayer.Character then
                local otherRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
                if otherRoot then
                    local distance = (otherRoot.Position - root.Position).Magnitude
                    if distance < 8 then
                        local direction = (otherRoot.Position - root.Position).Unit
                        otherRoot.AssemblyLinearVelocity = direction * 100 + Vector3.new(0, 50, 0)
                    end
                end
            end
        end
    end)
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        helicopterConnections.died = humanoid.Died:Connect(function()
            disableHelicopter()
        end)
    end
end

local function disableHelicopter()
    if not HELICOPTER_ENABLED then return end
    HELICOPTER_ENABLED = false
    
    for _, conn in pairs(helicopterConnections) do
        pcall(function() conn:Disconnect() end)
    end
    helicopterConnections = {}
    
    if helicopterBodyAngularVelocity then
        helicopterBodyAngularVelocity:Destroy()
        helicopterBodyAngularVelocity = nil
    end
end

-- ============================================
-- FLOAT TO PLOT FUNCTION
-- ============================================
local floatToPlotActive = false
local floatToPlotConnection = nil

local function findNearestPlot()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end
    
    local nearestPlot = nil
    local nearestDistance = 500
    
    for _, plot in ipairs(plotsFolder:GetChildren()) do
        if plot:IsA("Model") then
            local plotPosition = plot:GetPivot().Position
            local distance = (myHRP.Position - plotPosition).Magnitude
            
            if distance < nearestDistance then
                nearestDistance = distance
                nearestPlot = plot
            end
        end
    end
    
    return nearestPlot, nearestDistance
end

local function enableFloatToPlot()
    if floatToPlotActive then return end
    floatToPlotActive = true
    
    floatToPlotConnection = RunService.Heartbeat:Connect(function()
        if not floatToPlotActive then return end
        
        local myChar = LocalPlayer.Character
        if not myChar then return end
        
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        
        local targetPlot, distance = findNearestPlot()
        if targetPlot and distance > 5 then
            local plotPosition = targetPlot:GetPivot().Position
            local direction = (plotPosition - myHRP.Position).Unit
            local speed = 50
            
            myHRP.AssemblyLinearVelocity = Vector3.new(
                direction.X * speed,
                myHRP.AssemblyLinearVelocity.Y,
                direction.Z * speed
            )
        end
    end)
end

local function disableFloatToPlot()
    floatToPlotActive = false
    if floatToPlotConnection then
        floatToPlotConnection:Disconnect()
        floatToPlotConnection = nil
    end
end

-- ============================================
-- FREEZE FUNCTION
-- ============================================
local freezeActive = false
local freezeConnection = nil
local freezeWeld = nil
local freezeGround = nil
local freezeBodyPos = nil

local function enableFreeze()
    if freezeActive then return end
    
    local myChar = LocalPlayer.Character
    if not myChar then return end
    
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    
    freezeActive = true
    
    local savedPos = myHRP.Position
    local savedCF = myHRP.CFrame
    
    freezeGround = Instance.new("Part")
    freezeGround.Name = "FreezeGround"
    freezeGround.Size = Vector3.new(10, 1, 10)
    freezeGround.Position = savedPos - Vector3.new(0, 3, 0)
    freezeGround.Anchored = true
    freezeGround.CanCollide = true
    freezeGround.Transparency = 1
    freezeGround.Parent = workspace
    
    freezeWeld = Instance.new("WeldConstraint")
    freezeWeld.Part0 = myHRP
    freezeWeld.Part1 = freezeGround
    freezeWeld.Parent = myHRP
    
    freezeBodyPos = Instance.new("BodyPosition")
    freezeBodyPos.Position = savedPos
    freezeBodyPos.MaxForce = Vector3.new(4000, 4000, 4000)
    freezeBodyPos.P = 2000
    freezeBodyPos.Parent = myHRP
    
    freezeConnection = RunService.Heartbeat:Connect(function()
        if not freezeActive or not myHRP or myHRP.Parent ~= myChar then
            return
        end
        
        myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        if freezeBodyPos then
            freezeBodyPos.Position = savedPos
        end
        
        pcall(function()
            myHRP.CFrame = savedCF
        end)
    end)
end

local function disableFreeze()
    freezeActive = false
    
    if freezeConnection then
        freezeConnection:Disconnect()
        freezeConnection = nil
    end
    
    if freezeWeld then
        freezeWeld:Destroy()
        freezeWeld = nil
    end
    
    if freezeGround then
        freezeGround:Destroy()
        freezeGround = nil
    end
    
    if freezeBodyPos then
        freezeBodyPos:Destroy()
        freezeBodyPos = nil
    end
end

