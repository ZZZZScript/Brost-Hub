-- FLOAT FUNCTION
-- ============================================
local FLOAT_ENABLED = false
local floatConnections = {}
local floatBodyVelocity = nil
local floatPart = nil

local function enableFloat(character)
    if FLOAT_ENABLED then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    
    FLOAT_ENABLED = true
    
    floatPart = Instance.new("Part")
    floatPart.Size = Vector3.new(4, 1, 4)
    floatPart.Transparency = 1
    floatPart.Anchored = false
    floatPart.CanCollide = false
    floatPart.Massless = true
    floatPart.Parent = workspace
    
    local weld = Instance.new("Weld")
    weld.Part0 = rootPart
    weld.Part1 = floatPart
    weld.C0 = CFrame.new(0, -3.5, 0)
    weld.Parent = floatPart
    
    floatBodyVelocity = Instance.new("BodyVelocity")
    floatBodyVelocity.MaxForce = Vector3.new(0, 5000, 0)
    floatBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    floatBodyVelocity.P = 1000
    floatBodyVelocity.Parent = floatPart
    
    floatConnections.stepped = RunService.Stepped:Connect(function()
        if not FLOAT_ENABLED or not humanoid or humanoid.Health <= 0 then
            return
        end
        
        local isInAir = humanoid:GetState() == Enum.HumanoidStateType.Freefall
        local isJumping = humanoid:GetState() == Enum.HumanoidStateType.Jumping
        local isFalling = humanoid:GetState() == Enum.HumanoidStateType.FallingDown
        
        local raycast = workspace:Raycast(rootPart.Position, Vector3.new(0, -10, 0))
        local isOnGround = raycast ~= nil
        
        if isInAir or isJumping or isFalling or not isOnGround then
            floatBodyVelocity.Velocity = Vector3.new(0, -2.5, 0)
        else
            floatBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
    
    floatConnections.died = humanoid.Died:Connect(function()
        disableFloat()
    end)
end

local function disableFloat()
    FLOAT_ENABLED = false
    for _, conn in pairs(floatConnections) do
        pcall(function() conn:Disconnect() end)
    end
    floatConnections = {}
    
    if floatPart then
        floatPart:Destroy()
        floatPart = nil
    end
end

